# API key required on every /api/* request via the x-api-key header.
# Generate with: openssl rand -hex 32
API_KEY=replace-with-long-random-string

# FMCSA QCMobile API key. Get one at https://mobile.fmcsa.dot.gov/developer
FMCSA_WEBKEY=replace-with-fmcsa-web-key

# Path to SQLite file. Defaults to ./data/happyrobot.db inside the container.
DATABASE_PATH=./data/happyrobot.db
